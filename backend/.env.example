# Example Environment Variables for Backend

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (if switching from SQLite to PostgreSQL)
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASS=yourpassword
# DB_NAME=travel_loyalty

# JWT Secret for Authentication
JWT_SECRET=your_super_secret_key_here

# Email Configuration (for sending invitations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_APP_PASSWORD=your_16_char_google_app_password
