# Example Environment Variables for Backend

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (if switching from SQLite to PostgreSQL)
# DB_HOST=localhost
# DB_USER=postgres
# DB_PASS=yourpassword
# DB_NAME=travel_loyalty

# JWT Secret for Authentication
JWT_SECRET=your_super_secret_key_here

# Email Configuration (for sending invitations)
# Recommended Provider: Brevo (Sendinblue)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SENDER_EMAIL=your_registered_brevo_email@example.com
SENDER_APP_PASSWORD=your_brevo_smtp_key
SMTP_FROM="Travel Loyalty Team <your_registered_brevo_email@example.com>"
